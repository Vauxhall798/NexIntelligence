{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/client",
        "buildCommand": "npm run build"
      }
    },
    {
      "src": "api/health.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/documents.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/ask.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/ingest.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/api/(.*)",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"],
      "dest": "/api/$1"
    },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
